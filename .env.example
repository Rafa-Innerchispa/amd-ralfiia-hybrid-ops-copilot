# RalfIIA Hybrid Ops Copilot — AMD ACT II Track 3
# Copiar a .env — NUNCA commitear secretos

# Root gateway
ROOT_GATEWAY_HOST=0.0.0.0
ROOT_GATEWAY_PORT=8220
PUBLIC_BASE_URL=http://192.168.1.4:8220

# LiteLLM / vLLM (AMD Academy reference — optional local profile)
VLLM_MODEL=hosted_vllm/meta-llama/Llama-3.1-8B-Instruct
OPENAI_API_BASE=http://host.docker.internal:8088/v1

# Ollama local + nodos RalfIA
OLLAMA_MODEL=ollama_chat/llama3.1:latest
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_AMD_URL=http://192.168.1.5:11434
OLLAMA_PRIMARY_URL=http://192.168.1.4:11434
OLLAMA_INTAKE_MODEL=qwen2.5:7b

# Fireworks AMD (Track 1 cloud LLM)
# IDs Gemma requieren prefijo accounts/fireworks/models/...
# Gemma NO aparece en GET /models hasta hacer "Deploy on Demand" en app.fireworks.ai
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_API_BASE=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v4-pro
FIREWORKS_COMPLEX_MODEL=accounts/fireworks/models/deepseek-v4-pro
FIREWORKS_CAPTION_MODEL=accounts/fireworks/models/gemma-2-9b-it
# Evaluador AMD inyecta ALLOWED_MODELS — no hardcodear en producción Track 1

# AMD Developer Cloud (DigitalOcean GPU credits — dop_v1 token)
AMD_CLOUD_API_TOKEN=
AMD_CLOUD_API_BASE=https://api.digitalocean.com/v2
# Tras desplegar vLLM en droplet MI300X:
AMD_INFERENCE_BASE_URL=
AMD_INFERENCE_API_KEY=not-required
AMD_INFERENCE_MODEL=Qwen/Qwen2.5-1.5B-Instruct
HARNESS_INPUT_PATH=/input/tasks.json
HARNESS_OUTPUT_PATH=/output/results.json

# A2A worker agents (internal docker DNS + host ports)
SMART_QUOTER_AGENT_AUTH=quoter_bearer_token_change_me
SMART_QUOTER_AGENT_URL=http://agent-smart-quoter:8221
WATCHDOG_AGENT_AUTH=watchdog_bearer_token_change_me
WATCHDOG_AGENT_URL=http://agent-watchdog:8222

# Legacy tutorial aliases (mapped to our workers)
PIZZA_SELLER_AGENT_AUTH=quoter_bearer_token_change_me
PIZZA_SELLER_AGENT_URL=http://agent-smart-quoter:8221
BURGER_SELLER_AGENT_AUTH=watchdog_bearer_token_change_me
BURGER_SELLER_AGENT_URL=http://agent-watchdog:8222

# Mongo (local bare-metal; use host.docker.internal only inside docker compose)
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB=pcdoctor_swarm

# MCP RalfIA (optional enrichment)
MCP_RALFIA_URL=http://host.docker.internal:8102
MCP_RALFIA_TOKEN=

# Smart Quoter + Panel (host services — demo integrado)
SMART_QUOTER_URL=http://host.docker.internal:2026
SMART_PORTAL_URL=http://192.168.1.4:2002
PUBLIC_NGROK_BASE=https://your-ngrok-subdomain.ngrok-free.dev
PUBLIC_AMD_OPS_PATH=/amd-ops
PUBLIC_AMD_API_PATH=/amd-ops-api
